# repo-foundation managed baseline (regenerated by sync; edit outside this block)

# macOS Finder and resource-fork noise
.DS_Store
._*

# Editor and IDE scratch files
*~
*.swp
*.swo
.idea/
.vscode/

# Bundler: the vendored gems and the cache are not tracked, but .bundle/config
# IS — it pins the gem layout (BUNDLE_PATH=vendor/bundle). See
# docs/agent-principles.md.
vendor/bundle/
.bundle/cache/
*.gem

# end repo-foundation managed baseline

# Personal session artifacts (never commit)
/OPENING_PROMPT.txt

# Saved iterations of working files
*.md.[0-9]
*.sh.[0-9]

# Local-only working directory (year+ of pre-rm-rf prototypes; preserved on disk for reference but not committed since refactor/modular branch supersedes it)
/archive/

# Cache directory
.cache/

# Compiled binaries
*.o
*.a
*.dylib
*.so

# Temp files
*.tmp
*.bak
