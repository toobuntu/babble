# Function to execute Ruby with the correct interpreter
execute_ruby() {
  unset HOMEBREW_RUBY_WARNINGS
  HOMEBREW_RUBY_WARNINGS="${HOMEBREW_RUBY_WARNINGS:-"-W1"}"
  exec "${HOMEBREW_RUBY_PATH}" "${HOMEBREW_RUBY_WARNINGS}" "${HOMEBREW_RUBY_DISABLE_OPTIONS}" "$@"
}

# Main function to call all other functions
main() {
  initialize_homebrew
  set_platform_variables
  source_homebrew_helpers
  setup_ruby
  echo "HOMEBREW_RUBY_PATH after setup-ruby in main(): $HOMEBREW_RUBY_PATH" >&2
  execute_ruby "$@"
}

# Entry point
main "$@"
